WITH AW_ASSIGNMENT_HISTORY AS (
    SELECT 
        'AW_ASSIGNMENT_HISTORY' CATEGORY,
        DCR.CTRL_SEQ,
        DCR.TABROWID,
        PAA.PERSON_ID,
        DCR.PROCEDURE_NAME,
        DCR.TABLE_NAME,
        DC.PROCESSFIELDNAME,
        DC.RULE_CATEGORY
    FROM DQ_CLEANSE_RESULTS DCR
    JOIN DQ_CONTROL DC ON DC.CTRL_SEQ = DCR.CTRL_SEQ
    JOIN DQ_PER_ALL_ASSIGNMENTS_F_v PAA ON PAA.TABROWID = DCR.TABROWID
    JOIN ( 
            SELECT 
                DISTINCT ASSIGNMENT_ID
            FROM DQ_ASSIGNMENT_LOOKUP_V  
            WHERE ASSIGNMENT_CATEGORY = 'AW_ASSIGNMENT_HISTORY'
    ) AL ON AL.ASSIGNMENT_ID = PAA.ASSIGNMENT_ID
    WHERE
        DCR.SUB_DOMAIN_NAME = 'ACTIVE_ASS_FY_HISTORY'
        AND DCR.BATCH_SEQ = (SELECT MAX(BATCH_SEQ) FROM DQ_CONTROL WHERE SUB_DOMAIN_NAME = 'ACTIVE_ASS_FY_HISTORY')
    ),

AW_ACTIVE_ASSIGNMENTS AS (
    SELECT 
        'AW_ACTIVE_ASSIGNMENTS' CATEGORY,
        DCR.CTRL_SEQ,
        DCR.TABROWID,
        PAA.PERSON_ID,
        DCR.PROCEDURE_NAME,
        DCR.TABLE_NAME,
        DC.PROCESSFIELDNAME,
        DC.RULE_CATEGORY
    FROM DQ_CLEANSE_RESULTS DCR
    JOIN DQ_CONTROL DC ON DC.CTRL_SEQ = DCR.CTRL_SEQ
    JOIN DQ_PER_ALL_ASSIGNMENTS_F_v PAA ON PAA.TABROWID = DCR.TABROWID
    JOIN ( 
            SELECT 
                DISTINCT ASSIGNMENT_ID
            FROM DQ_ASSIGNMENT_LOOKUP_V  
            WHERE ASSIGNMENT_CATEGORY = 'AW_ACTIVE_ASSIGNMENTS'
    ) AL ON AL.ASSIGNMENT_ID = PAA.ASSIGNMENT_ID
    WHERE
        DCR.SUB_DOMAIN_NAME = 'ACTIVE_ASS_FY_HISTORY'
        AND DCR.BATCH_SEQ = (SELECT MAX(BATCH_SEQ) FROM DQ_CONTROL WHERE SUB_DOMAIN_NAME = 'ACTIVE_ASS_FY_HISTORY')
)
