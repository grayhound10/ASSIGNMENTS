-- Privileges you have in UAT but NOT in DEV
SELECT OWNER, TABLE_NAME, PRIVILEGE
FROM ALL_TAB_PRIVS_RECD@UAT_HR
MINUS
SELECT OWNER, TABLE_NAME, PRIVILEGE
FROM ALL_TAB_PRIVS_RECD@DEV_HR;

-- Privileges you have in DEV but NOT in UAT
SELECT OWNER, TABLE_NAME, PRIVILEGE
FROM ALL_TAB_PRIVS_RECD@DEV_HR
MINUS
SELECT OWNER, TABLE_NAME, PRIVILEGE
FROM ALL_TAB_PRIVS_RECD@UAT_HR;
Also compare what objects are visible:


-- Objects visible in UAT but NOT DEV
SELECT OWNER, OBJECT_NAME, OBJECT_TYPE
FROM ALL_OBJECTS@UAT_HR
WHERE OBJECT_TYPE IN ('TABLE','VIEW','SYNONYM')
MINUS
SELECT OWNER, OBJECT_NAME, OBJECT_TYPE
FROM ALL_OBJECTS@DEV_HR
WHERE OBJECT_TYPE IN ('TABLE','VIEW','SYNONYM');

-- Objects visible in DEV but NOT UAT
SELECT OWNER, OBJECT_NAME, OBJECT_TYPE
FROM ALL_OBJECTS@DEV_HR
WHERE OBJECT_TYPE IN ('TABLE','VIEW','SYNONYM')
MINUS
SELECT OWNER, OBJECT_NAME, OBJECT_TYPE
FROM ALL_OBJECTS@UAT_HR
WHERE OBJECT_TYPE IN ('TABLE','VIEW','SYNONYM');
